{
  "_comment": "Reference hook configuration. Merge these entries into your ~/.claude/settings.json under the 'hooks' key. Replace HOME_DIR with your actual home directory path.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node HOME_DIR/.claude/hooks/scripts/session-reset.js",
            "timeout": 3
          }
        ],
        "description": "Reset fact-forcing gate tracker for clean session state",
        "id": "session:reset-tracker"
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node HOME_DIR/.claude/hooks/scripts/prompt-enrich-trigger.js",
            "timeout": 3
          }
        ],
        "description": "Detect vague prompts and inject forcing instruction for prompt-enrichment skill",
        "id": "prompt:enrich-trigger"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node HOME_DIR/.claude/hooks/scripts/session-self-improve-prompt.js",
            "timeout": 5
          }
        ],
        "description": "H.4.1: on first prompt of session, inject pending self-improve queue if non-empty (closes the manual /self-improve loop)",
        "id": "prompt:self-improve-queue"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node HOME_DIR/.claude/hooks/scripts/plugin-loaded-check.js",
            "timeout": 5
          }
        ],
        "description": "H.7.22: surface [PLUGIN-NOT-LOADED] forcing instruction when marketplace registered but plugin not enabled (closes drift-note 33 — observability without surfacing)",
        "id": "prompt:plugin-loaded-check"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node HOME_DIR/.claude/hooks/scripts/fact-force-gate.js",
            "timeout": 5
          }
        ],
        "description": "Fact-forcing gate: must Read a file before Edit/Write — prevents hallucinated edits",
        "id": "pre:fact-force-gate"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node HOME_DIR/.claude/hooks/scripts/config-guard.js",
            "timeout": 5
          }
        ],
        "description": "Block modifications to linter/formatter config files — fix code, not configs",
        "id": "pre:config-guard"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node HOME_DIR/.claude/hooks/scripts/validators/validate-no-bare-secrets.js",
            "timeout": 5
          }
        ],
        "description": "H.4.2: Block writes containing secret-shaped literals (Anthropic/Stripe/Slack/GitHub/AWS keys, JWT, *_KEY/*_SECRET assignments). Hook-layer enforcement of the security.md pre-commit checklist.",
        "id": "pre:validate-no-bare-secrets"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node HOME_DIR/.claude/hooks/scripts/validators/validate-frontmatter-on-skills.js",
            "timeout": 5
          }
        ],
        "description": "H.4.2: Block Write of skill/pattern .md files that lack YAML frontmatter (silently-broken skills are worse than visibly-broken ones).",
        "id": "pre:validate-frontmatter-on-skills"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node HOME_DIR/.claude/hooks/scripts/pre-compact-save.js",
            "timeout": 10
          }
        ],
        "description": "Checkpoint context to file + instruct MemPalace save before compression",
        "id": "pre:compact-save"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node HOME_DIR/.claude/hooks/scripts/console-log-check.js",
            "timeout": 5
          }
        ],
        "description": "Warn about console.log statements in recently edited files",
        "id": "stop:console-check"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node HOME_DIR/.claude/hooks/scripts/auto-store-enrichment.js",
            "timeout": 10
          }
        ],
        "description": "Auto-store [ENRICHED-PROMPT-START/END] blocks from response into prompt-patterns.json",
        "id": "stop:auto-store-enrichment"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node HOME_DIR/.claude/hooks/scripts/session-end-nudge.js",
            "timeout": 3
          }
        ],
        "description": "After N responses, nudge user toward /self-improve (closes the session-end review loop)",
        "id": "stop:session-end-nudge"
      }
    ]
  }
}
