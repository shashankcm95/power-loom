{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/Documents/claude-toolkit/hooks/scripts/config-guard.js",
            "timeout": 5
          }
        ],
        "description": "Block modifications to linter/formatter config files — fix code, not configs",
        "id": "pre:config-guard"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/Documents/claude-toolkit/hooks/scripts/pre-compact-save.js"
          }
        ],
        "description": "Save critical context before context window compression",
        "id": "pre:compact-save"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/Documents/claude-toolkit/hooks/scripts/console-log-check.js"
          }
        ],
        "description": "Warn about console.log statements in recently edited files",
        "id": "stop:console-check"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/Documents/claude-toolkit/hooks/scripts/desktop-notify.js",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "macOS notification when Claude finishes a response",
        "id": "stop:desktop-notify"
      }
    ]
  }
}
